{
  "name": "tread-sync-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Integration runtime for tread-sync-hub: REST API, EDI X12, CSV file routing, SFTP polling.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seed.ts",
    "smoke": "bash scripts/smoke.sh"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@supabase/supabase-js": "^2.45.0",
    "fastify": "^5.0.0",
    "node-cron": "^3.0.3",
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/ssh2-sftp-client": "^9.0.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
