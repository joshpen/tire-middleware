# Supabase (shared with tread-sync-hub; service-role key stays server-side only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# HTTP server
PORT=8080
HOST=0.0.0.0

# File endpoint polling (node-cron expression); empty disables the scheduler
POLL_CRON=*/15 * * * *

# Admin dashboard (/ui) sign-in token; falls back to the service-role key if unset
GATEWAY_ADMIN_TOKEN=
